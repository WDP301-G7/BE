// prisma/schema.prisma
// =============================================
// ERD HỆ THỐNG BÁN KÍNH ONLINE
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS
// ============================================

model User {
  id        String     @id @default(uuid())
  fullName  String     @map("full_name") @db.VarChar(150)
  email     String     @unique @db.VarChar(150)
  phone     String?    @unique @db.VarChar(20)
  password  String     @db.VarChar(255)
  avatarUrl String?    @map("avatar_url") @db.VarChar(255)
  role      UserRole
  status    UserStatus
  storeId   String?    @map("store_id")
  address   String?    @db.VarChar(255)
  
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  
  // Relations
  store                          Store?                 @relation(fields: [storeId], references: [id])
  ordersAsCustomer               Order[]                @relation("CustomerOrders")
  ordersAsHandler                Order[]                @relation("HandlerOrders")
  prescriptionsAsCustomer        Prescription[]         @relation("CustomerPrescriptions")
  prescriptionsAsMeasurer        Prescription[]         @relation("MeasurerPrescriptions")
  returnRequestsAsCustomer       ReturnRequest[]        @relation("CustomerReturnRequests")
  returnRequestsAsHandler        ReturnRequest[]        @relation("HandlerReturnRequests")
  returnImageUploads             ReturnRequestImage[]   @relation("ReturnImageUploader")
  prescriptionRequestsAsCustomer PrescriptionRequest[]  @relation("CustomerPrescriptionRequests")
  prescriptionRequestsAsHandler  PrescriptionRequest[]  @relation("HandlerPrescriptionRequests")
  reviewsAsCustomer              Review[]               @relation("CustomerReviews")
  reviewReplies                  Review[]               @relation("ReviewReplier")
  
  @@map("users")
  @@index([storeId])
  @@index([email])
  @@index([role])
}

enum UserRole {
  CUSTOMER
  STAFF
  OPERATION
  MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

// ============================================
// STORES
// ============================================

model Store {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  address   String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  users                User[]
  inventory            Inventory[]
  prescriptionRequests PrescriptionRequest[]
  pickupOrders         Order[]              @relation("PickupStore")
  
  @@map("stores")
}

// ============================================
// CATEGORIES
// ============================================

model Category {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relations
  products Product[]
  
  @@map("categories")
}

// ============================================
// PRODUCTS
// ============================================

model Product {
  id            String      @id @default(uuid())
  categoryId    String      @map("category_id")
  name          String      @db.VarChar(150)
  description   String?     @db.Text
  type          ProductType
  price         Decimal     @db.Decimal(10, 2)
  isPreorder    Boolean     @default(false) @map("is_preorder")
  leadTimeDays  Int?        @map("lead_time_days")
  sku           String?     @db.VarChar(50)
  brand         String?     @db.VarChar(100)
  deletedAt     DateTime?   @map("deleted_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  
  // Relations
  category           Category       @relation(fields: [categoryId], references: [id])
  images             ProductImage[]
  inventory          Inventory[]
  orderItems         OrderItem[]
  returnItems        ReturnItem[]   @relation("ReturnProduct")
  exchangeReturnItems ReturnItem[]  @relation("ExchangeProduct")
  reviews            Review[]
  
  @@map("products")
  @@index([categoryId])
  @@index([type])
  @@index([deletedAt])
}

enum ProductType {
  FRAME
  LENS
  SERVICE
}

// ============================================
// PRODUCT IMAGES
// ============================================

model ProductImage {
  id         String           @id @default(uuid())
  productId  String           @map("product_id")
  imageUrl   String           @map("image_url") @db.VarChar(255)
  imageType  ProductImageType @map("image_type")
  isPrimary  Boolean          @default(false) @map("is_primary")
  createdAt  DateTime         @default(now()) @map("created_at")
  
  // Relations
  product Product @relation(fields: [productId], references: [id])
  
  @@map("product_images")
  @@index([productId])
}

enum ProductImageType {
  TWO_D   @map("2D")
  THREE_D @map("3D")
  DETAIL
}

// ============================================
// INVENTORY
// ============================================

model Inventory {
  id               String   @id @default(uuid())
  productId        String   @map("product_id")
  storeId          String   @map("store_id")
  quantity         Int
  reservedQuantity Int      @default(0) @map("reserved_quantity")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  // Relations
  product Product @relation(fields: [productId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  
  @@map("inventory")
  @@index([productId])
  @@index([storeId])
}

// ============================================
// ORDERS
// ============================================

model Order {
  id                String         @id @default(uuid())
  customerId        String         @map("customer_id")
  orderType         OrderType      @map("order_type")
  status            OrderStatus
  paymentStatus     PaymentStatus  @map("payment_status")
  depositAmount     Decimal?       @map("deposit_amount") @db.Decimal(10, 2)
  totalAmount       Decimal        @map("total_amount") @db.Decimal(10, 2)
  expectedReadyDate DateTime?      @map("expected_ready_date")
  appointmentDate   DateTime?      @map("appointment_date")
  appointmentNote   String?        @map("appointment_note") @db.Text
  handledBy         String?        @map("handled_by")
  
  // Prescription flow fields
  pickupStoreId     String?        @map("pickup_store_id")
  expiresAt         DateTime?      @map("expires_at")
  quotedAt          DateTime?      @map("quoted_at")
  
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  
  // Relations
  customer            User              @relation("CustomerOrders", fields: [customerId], references: [id])
  handler             User?             @relation("HandlerOrders", fields: [handledBy], references: [id])
  pickupStore         Store?            @relation("PickupStore", fields: [pickupStoreId], references: [id])
  orderItems          OrderItem[]
  prescription        Prescription?
  prescriptionRequest PrescriptionRequest?
  payments            Payment[]
  returnRequests      ReturnRequest[]
  reviews             Review[]
  
  @@map("orders")
  @@index([customerId])
  @@index([handledBy])
  @@index([status])
  @@index([orderType])
}

enum OrderType {
  IN_STOCK
  PRE_ORDER
  PRESCRIPTION
}

enum OrderStatus {
  NEW
  CONFIRMED
  WAITING_CUSTOMER
  WAITING_PRODUCT
  PROCESSING
  READY
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  UNPAID
  DEPOSITED
  PAID
}

// ============================================
// ORDER ITEMS
// ============================================

model OrderItem {
  id         String          @id @default(uuid())
  orderId    String          @map("order_id")
  productId  String          @map("product_id")
  quantity   Int
  unitPrice  Decimal         @map("unit_price") @db.Decimal(10, 2)
  itemStatus OrderItemStatus @map("item_status")
  note       String?         @db.Text
  
  // Relations
  order       Order        @relation(fields: [orderId], references: [id])
  product     Product      @relation(fields: [productId], references: [id])
  returnItems ReturnItem[]
  review      Review?
  
  @@map("order_items")
  @@index([orderId])
  @@index([productId])
}

enum OrderItemStatus {
  PENDING
  PROCESSING
  READY
  DELIVERED
}

// ============================================
// PRESCRIPTIONS
// ============================================

model Prescription {
  id                    String   @id @default(uuid())
  orderId               String   @unique @map("order_id")
  customerId            String   @map("customer_id")
  prescriptionImageUrl  String   @map("prescription_image_url") @db.VarChar(255)
  notes                 String?  @db.Text
  measuredBy            String?  @map("measured_by")
  
  // Eye measurements
  rightEyeSphere        Decimal? @map("right_eye_sphere") @db.Decimal(4, 2)
  rightEyeCylinder      Decimal? @map("right_eye_cylinder") @db.Decimal(4, 2)
  rightEyeAxis          Int?     @map("right_eye_axis")
  leftEyeSphere         Decimal? @map("left_eye_sphere") @db.Decimal(4, 2)
  leftEyeCylinder       Decimal? @map("left_eye_cylinder") @db.Decimal(4, 2)
  leftEyeAxis           Int?     @map("left_eye_axis")
  pupillaryDistance     Decimal? @map("pupillary_distance") @db.Decimal(4, 1)
  
  createdAt             DateTime @default(now()) @map("created_at")
  
  // Relations
  order      Order @relation(fields: [orderId], references: [id])
  customer   User  @relation("CustomerPrescriptions", fields: [customerId], references: [id])
  measurer   User? @relation("MeasurerPrescriptions", fields: [measuredBy], references: [id])
  
  @@map("prescriptions")
  @@index([customerId])
  @@index([measuredBy])
}

// ============================================
// PRESCRIPTION REQUESTS
// ============================================

model PrescriptionRequest {
  id                String                      @id @default(uuid())
  customerId        String                      @map("customer_id")
  phone             String                      @db.VarChar(20)
  storeId           String                      @map("store_id")
  consultationType  ConsultationType            @map("consultation_type")
  symptoms          String?                     @db.Text
  status            PrescriptionRequestStatus
  
  contactedAt       DateTime?                   @map("contacted_at")
  contactNotes      String?                     @map("contact_notes") @db.Text
  handledBy         String?                     @map("handled_by")
  
  orderId           String?                     @unique @map("order_id")
  appointmentDate   DateTime?                   @map("appointment_date")
  
  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @updatedAt @map("updated_at")
  expiresAt         DateTime?                   @map("expires_at")
  
  // Relations
  customer User   @relation("CustomerPrescriptionRequests", fields: [customerId], references: [id])
  store    Store  @relation(fields: [storeId], references: [id])
  handler  User?  @relation("HandlerPrescriptionRequests", fields: [handledBy], references: [id])
  order    Order? @relation(fields: [orderId], references: [id])
  images   PrescriptionRequestImage[]
  
  @@map("prescription_requests")
  @@index([customerId])
  @@index([storeId])
  @@index([status])
  @@index([handledBy])
}

model PrescriptionRequestImage {
  id        String   @id @default(uuid())
  requestId String   @map("request_id")
  imageUrl  String   @map("image_url") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  
  request PrescriptionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  @@map("prescription_request_images")
  @@index([requestId])
}

enum ConsultationType {
  PHONE
  IN_STORE
}

enum PrescriptionRequestStatus {
  PENDING
  CONTACTING
  QUOTED
  ACCEPTED
  REJECTED
  LOST
  EXPIRED
  SCHEDULED
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @map("order_id")
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatusEnum
  paidAt    DateTime?     @map("paid_at")
  
  // Relations
  order Order @relation(fields: [orderId], references: [id])
  
  @@map("payments")
  @@index([orderId])
  @@index([status])
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  VNPAY
  MOMO
}

enum PaymentStatusEnum {
  PENDING
  SUCCESS
  FAILED
}

// ============================================
// RETURN REQUESTS
// ============================================

model ReturnRequest {
  id                String        @id @default(uuid())
  orderId           String        @map("order_id")
  customerId        String        @map("customer_id")
  type              ReturnType
  status            ReturnStatus
  channel           ReturnChannel
  
  // Thông tin yêu cầu
  reason            String        @db.Text
  description       String?       @db.Text
  
  // Xử lý
  handledBy         String?       @map("handled_by")
  approvedAt        DateTime?     @map("approved_at")
  rejectedAt        DateTime?     @map("rejected_at")
  rejectionReason   String?       @map("rejection_reason") @db.Text
  completedAt       DateTime?     @map("completed_at")
  
  // Bảo hành
  warrantyExpiredAt DateTime?     @map("warranty_expired_at") @db.Date
  
  // Hoàn tiền (RETURN)
  refundAmount      Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  refundMethod      RefundMethod? @map("refund_method")
  refundedAt        DateTime?     @map("refunded_at")
  
  // Đổi hàng (EXCHANGE)
  priceDifference   Decimal?      @map("price_difference") @db.Decimal(10, 2)
  
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  
  // Relations
  order      Order                 @relation(fields: [orderId], references: [id])
  customer   User                  @relation("CustomerReturnRequests", fields: [customerId], references: [id])
  handler    User?                 @relation("HandlerReturnRequests", fields: [handledBy], references: [id])
  items      ReturnItem[]
  images     ReturnRequestImage[]
  
  @@map("return_requests")
  @@index([orderId])
  @@index([customerId])
  @@index([handledBy])
  @@index([status])
  @@index([type])
}

model ReturnItem {
  id                String           @id @default(uuid())
  returnRequestId   String           @map("return_request_id")
  orderItemId       String           @map("order_item_id")
  productId         String           @map("product_id")
  quantity          Int
  condition         ProductCondition
  exchangeProductId String?          @map("exchange_product_id")
  createdAt         DateTime         @default(now()) @map("created_at")
  
  // Relations
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id])
  product         Product       @relation("ReturnProduct", fields: [productId], references: [id])
  exchangeProduct Product?      @relation("ExchangeProduct", fields: [exchangeProductId], references: [id])
  
  @@map("return_items")
  @@index([returnRequestId])
  @@index([orderItemId])
}

model ReturnRequestImage {
  id              String          @id @default(uuid())
  returnRequestId String          @map("return_request_id")
  imageUrl        String          @map("image_url") @db.VarChar(255)
  imageType       ReturnImageType @map("image_type")
  uploadedBy      String          @map("uploaded_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  
  // Relations
  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  uploader      User          @relation("ReturnImageUploader", fields: [uploadedBy], references: [id])
  
  @@map("return_request_images")
  @@index([returnRequestId])
  @@index([uploadedBy])
}

enum ReturnType {
  RETURN
  EXCHANGE
  WARRANTY
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum ReturnChannel {
  IN_STORE
}

enum RefundMethod {
  CASH
  BANK_TRANSFER
}

enum ProductCondition {
  NEW
  LIKE_NEW
  GOOD
  DAMAGED
  DEFECTIVE
}

enum ReturnImageType {
  CUSTOMER_PRODUCT
  CUSTOMER_DEFECT
  STAFF_RECEIVED
  STAFF_INSPECTION
  OTHER
}

// ============================================
// REVIEWS
// ============================================

model Review {
  id          String       @id @default(uuid())
  orderItemId String       @unique @map("order_item_id")
  orderId     String       @map("order_id")
  productId   String       @map("product_id")
  customerId  String       @map("customer_id")

  rating        Int
  comment       String?      @db.Text

  status        ReviewStatus @default(PUBLISHED)
  editableUntil DateTime     @map("editable_until")
  deletedAt     DateTime?    @map("deleted_at")

  replyContent  String?      @map("reply_content") @db.Text
  repliedBy     String?      @map("replied_by")
  repliedAt     DateTime?    @map("replied_at")

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Relations
  orderItem  OrderItem     @relation(fields: [orderItemId], references: [id])
  order      Order         @relation(fields: [orderId], references: [id])
  product    Product       @relation(fields: [productId], references: [id])
  customer   User          @relation("CustomerReviews", fields: [customerId], references: [id])
  replier    User?         @relation("ReviewReplier", fields: [repliedBy], references: [id])
  images     ReviewImage[]

  @@map("reviews")
  @@index([productId])
  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([rating])
  @@index([deletedAt])
}

model ReviewImage {
  id        String   @id @default(uuid())
  reviewId  String   @map("review_id")
  imageUrl  String   @map("image_url") @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_images")
  @@index([reviewId])
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
}
